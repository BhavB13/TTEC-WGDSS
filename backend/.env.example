DATABASE_URL=postgresql+psycopg2://wgdss:change_me@localhost:5432/wgdss
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_SINGLE_RUNS_URL=https://single-runs-api.open-meteo.com/v1/forecast
REPLAY_WEATHER_MODELS=ecmwf_ifs025,gfs_global,icon_global
REPLAY_WEATHER_RUN_AVAILABILITY_LAG_HOURS=6
REPLAY_WEATHER_CACHE_TTL_SECONDS=21600
MET_NORWAY_BASE_URL=https://api.met.no/weatherapi/locationforecast/2.0/compact
# MET Norway requires an identifiable User-Agent with contact information.
MET_NORWAY_USER_AGENT=TTEC-WGDSS/1.0 (+https://www.ttec.co.tt/)
WEATHER_API_BASE_URL=https://api.weatherapi.com/v1
# Optional $0 WeatherAPI fallback. Its free tier stops at quota; it does not
# automatically generate overage charges. Leave blank for a no-account setup.
WEATHER_API_KEY=
ENABLE_WEATHERAPI_FALLBACK=false
WEATHER_TIMEOUT_SECONDS=10
WEATHER_RETRY_ATTEMPTS=3
WEATHER_CACHE_TTL_SECONDS=300
WEATHER_CONSENSUS_TIMEOUT_SECONDS=12
# Safety ceiling below Open-Meteo's 10,000-call non-commercial daily limit.
OPEN_METEO_DAILY_REQUEST_LIMIT=9000
# Safety ceiling below WeatherAPI's 100,000-call Free-plan monthly limit.
WEATHER_API_MONTHLY_REQUEST_LIMIT=90000
DEFAULT_LATITUDE=10.5953
DEFAULT_LONGITUDE=-61.3372
WEATHER_SITE_ALTITUDE_METERS=12

DATABASE_AUTO_CREATE=false
SNAPSHOT_PERSISTENCE_ENABLED=true
DATA_STALE_AFTER_SECONDS=5400
# Selects the GridProvider implementation. Only mock is available until an
# approved read-only SCADA or historian connector is configured.
GRID_PROVIDER=mock
GRID_STALE_AFTER_SECONDS=30
MODEL_FORECAST_STALE_AFTER_SECONDS=7200
# Comma-separated YYYY-MM-DD dates for variable or specially declared holidays.
FORECAST_EXTRA_HOLIDAY_DATES=
CALIBRATION_DATA_ZIP_PATH=
CALIBRATION_AUTO_IMPORT=false

# Production-system demonstration mode. This is explicitly simulated and never
# represents a live T&TEC SCADA connection.
DEMO_REPLAY_ENABLED=true
DEMO_REPLAY_AUTO_SEED=true
DEMO_DATASET_YEAR=2025
DEMO_REPLAY_MONTH=6

# Optional historical SCADA replay source. Historical exports remain simulation
# and validation inputs; this does not configure a live SCADA connection.
SCADA_REPLAY_ARCHIVE_PATH=
SCADA_HISTORICAL_WEATHER_BACKFILL=false

# Historical trend-export quality/alignment policy. Confirm these values with
# T&TEC/OSI engineering before production use.
SCADA_STRICT_QUALITY_VALUES=Good
SCADA_CONDITIONAL_QUALITY_VALUES=Other
SCADA_MIN_HOURLY_COVERAGE=0.90
SCADA_MAX_HOURLY_COVERAGE=1.05
# Optional ISO-8601 source reporting window. Leave blank unless the requested
# export window is known; out-of-window intervals are flagged, not discarded.
SCADA_EXPECTED_REPORTING_START=
SCADA_EXPECTED_REPORTING_END=

# Capacity risk evaluates P(TRA - actual demand < required reserve). The 30 MW
# project target and every status/dispatch value below require T&TEC
# control-engineering confirmation before an operational deployment.
OPERATING_POLICY_STATUS=PROTOTYPE_UNCONFIRMED
CAPACITY_RISK_REQUIRED_RESERVE_MW=30
CAPACITY_RISK_WATCH_PROBABILITY_THRESHOLD=0.20
CAPACITY_RISK_PREPARE_PROBABILITY_THRESHOLD=0.50
CAPACITY_RISK_ADD_GENERATION_PROBABILITY_THRESHOLD=0.80
FAST_START_UNIT_CAPACITY_MW=15
FAST_START_MAX_CAPACITY_MW=30
FAST_START_LEAD_TIME_MINUTES=20
HEAVY_START_MIN_CAPACITY_MW=60
HEAVY_START_MAX_CAPACITY_MW=120
HEAVY_START_LEAD_TIME_MINUTES=60

# Advisory aggregate capacity planner. The current 15 MW small-set value is a
# configurable prototype placeholder; three startable sets and the 20-minute
# lead time reflect current project context but still require utility approval.
CAPACITY_PLAN_SMALL_BLOCK_ID=small-fast-start
CAPACITY_PLAN_SMALL_BLOCK_LABEL=Small fast-start set
CAPACITY_PLAN_SMALL_BLOCK_CAPACITY_MW=15
CAPACITY_PLAN_SMALL_STARTABLE_COUNT=3
CAPACITY_PLAN_SMALL_STARTUP_LEAD_MINUTES=20
CAPACITY_PLAN_SMALL_VERIFICATION_STATUS=UNCONFIRMED
# Supply approved comma-separated heavy-set MW blocks before heavy guidance is
# enabled. Lead time alone is not enough to infer startable capacity.
CAPACITY_PLAN_HEAVY_BLOCKS_MW=
CAPACITY_PLAN_HEAVY_STARTUP_LEAD_MINUTES=60
CAPACITY_PLAN_HEAVY_VERIFICATION_STATUS=UNCONFIGURED
CAPACITY_PLAN_CONTEXT_TTL_SECONDS=900
CAPACITY_PLAN_MAX_CONTEXTS=128
LIVE_SCADA_SNAPSHOT_PATH=
LIVE_SCADA_SESSION_ROOT=var/live_scada_sessions
LIVE_SCADA_MODEL_ARTIFACT_PATH=
# Released direct-horizon artifact. Generate it offline with
# scripts/export_frozen_demand_model.py; joblib files are not committed.
FROZEN_DEMAND_MODEL_ARTIFACT_PATH=var/models/wgdss-demand-v5.joblib

# Periodic export worker. This is labelled BATCH_SCADA_EXPORT, never live.
SCADA_BATCH_INPUT_DIR=var/scada_batch/inbox
SCADA_BATCH_STATE_PATH=var/scada_batch/state.json
SCADA_BATCH_FILE_STABLE_SECONDS=60

# Future read-only historian boundary. It remains disabled and transport-free
# until every item is approved by T&TEC OT/OSI engineering.
HISTORIAN_READ_ONLY_ENABLED=false
HISTORIAN_ENDPOINT=
HISTORIAN_AUTH_MODE=
HISTORIAN_CA_CERT_PATH=
HISTORIAN_TAG_MAP_JSON=
HISTORIAN_UNITS_JSON=
HISTORIAN_QUALITY_POLICY=
HISTORIAN_NETWORK_ZONE=
HISTORIAN_STALE_AFTER_SECONDS=300
